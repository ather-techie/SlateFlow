# Port the server listens on (also the host-side port exposed by docker-compose)
PORT=3000

# Absolute path inside the container where liteboard.db is stored.
# /data is mapped to the liteboard-data Docker volume for persistence.
DATABASE_PATH=/data/liteboard.db

# Secret key used for signing sessions / JWTs — change this before going live.
SECRET=change-me-in-production
